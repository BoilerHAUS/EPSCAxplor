# EPSCAxplor backup configuration (#143).
# Copy to /etc/epsca/backup.env on the VPS, fill in the secrets, then:
#   sudo chown root:root /etc/epsca/backup.env && sudo chmod 600 /etc/epsca/backup.env
# NEVER commit the filled-in file — this .example is the only version in git.

# ─── restic repository (S3-compatible, e.g. OVH Object Storage) ───────────────
# OVH S3 endpoint form: s3:https://s3.<region>.io.cloud.ovh.net/<bucket>
RESTIC_REPOSITORY=s3:https://s3.gra.io.cloud.ovh.net/epsca-backups

# Repository encryption password. Prefer a file over an inline value:
#   printf '%s' 'a-long-random-passphrase' | sudo tee /etc/epsca/restic.pass >/dev/null
#   sudo chmod 600 /etc/epsca/restic.pass
# LOSE THIS AND THE BACKUPS ARE UNRECOVERABLE — store a copy in your password manager.
RESTIC_PASSWORD_FILE=/etc/epsca/restic.pass
# RESTIC_PASSWORD=          # alternative to RESTIC_PASSWORD_FILE (less safe)

# ─── S3 credentials ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
# REQUIRED for OVH (and most non-AWS S3): the region must match your bucket's,
# or restic signs with us-east-1 and the request signature is rejected. It is
# the region in your endpoint host, e.g. s3.gra.io.cloud.ovh.net → gra.
AWS_DEFAULT_REGION=gra

# ─── Postgres ────────────────────────────────────────────────────────────────
DB_NAME=epsca
DB_USER=epsca_user
# Substring match against `docker ps` names. Dokploy/Swarm mangles the compose
# service name and appends a task suffix, e.g. epscaxplor-epscadb-xmn3j9.1.<id>.
# VERIFY on the box: docker ps --format '{{.Names}}' | grep -i epscadb
PG_CONTAINER_FILTER=epscaxplor-epscadb

# ─── Qdrant ──────────────────────────────────────────────────────────────────
# Likewise, e.g. epscaxplor-epscaqdrant-cbwsyf.1.<id>. Verify with:
#   docker ps --format '{{.Names}}' | grep -i epscaqdrant
QDRANT_CONTAINER_FILTER=epscaxplor-epscaqdrant
QDRANT_PORT=6333
# Set once #144 lands (Qdrant API-key auth). Leave blank until then.
QDRANT_API_KEY=

# ─── Docker / tooling ────────────────────────────────────────────────────────
DOCKER_NETWORK=dokploy-network
CURL_IMAGE=curlimages/curl:8.10.1
STAGING_DIR=/var/lib/epsca-backups/staging

# ─── Retention ───────────────────────────────────────────────────────────────
KEEP_DAILY=7
KEEP_WEEKLY=4
BACKUP_HOST=epsca-vps

# Set to 1 to run a restic read-data check every run (slow). Off by default;
# prefer a separate weekly deep check (see runbook).
RESTIC_DEEP_CHECK=0
