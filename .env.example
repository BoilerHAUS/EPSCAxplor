# ─── Database ────────────────────────────────────────────────────────────────
# Individual credentials used by the epsca-db container
DB_NAME=epsca
DB_USER=epsca_user
DB_PASSWORD=replace-with-strong-password

# Connection string for the API service (must match the above credentials)
DATABASE_URL=postgresql://epsca_user:replace-with-strong-password@epsca-db:5432/epsca

# ─── Vector Store ────────────────────────────────────────────────────────────
# Qdrant REST API base URL (internal Docker network)
QDRANT_URL=http://epsca-qdrant:6333
# Qdrant API key (#144). Empty = keyless (local dev). For prod, generate with:
#   openssl rand -hex 32
# The SAME value must be set on the Qdrant service (compose maps it to
# QDRANT__SERVICE__API_KEY), on the API, on host-run ingestion, and in
# /etc/epsca/backup.env — or a client is locked out once auth is enforced.
QDRANT_API_KEY=

# ─── Embeddings ──────────────────────────────────────────────────────────────
# Ollama API base URL — uses host-gateway to reach the host from inside a container
OLLAMA_URL=http://host-gateway:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Claude API ──────────────────────────────────────────────────────────────
# Anthropic API key — never commit this value
ANTHROPIC_API_KEY=sk-ant-...

# Model identifiers — configurable to allow model upgrades without code changes
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to sign and verify JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-random-hex-string

# JWT expiry durations
JWT_ACCESS_EXPIRY_SECONDS=900         # 15 minutes
JWT_REFRESH_EXPIRY_DAYS=7             # 7 days

# ─── Application ─────────────────────────────────────────────────────────────
# Runtime environment — controls log verbosity and error detail in responses
ENVIRONMENT=development               # development | production

# CORS allowed origins — comma-separated list
CORS_ORIGINS=http://localhost:3000

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# Public API base URL — baked into the Next.js build at compile time
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── CI / Deployment ─────────────────────────────────────────────────────────
# GitHub container registry owner — set automatically in CI, override locally
GITHUB_REPOSITORY_OWNER=boilerhaus
# Git SHA used to pin image tags (compose ${GIT_SHA}) — defaults to "latest" if
# unset. CI also bakes the commit SHA into the API image as a build arg, which
# the app reports at /health so the deploy workflow can confirm the live build.
GIT_SHA=latest
